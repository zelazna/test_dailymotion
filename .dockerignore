# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info
dist/
build/
wheels/

# Virtual environments — CRITICAL: prevents local .venv from bloating context
.venv
venv
env

# uv cache
.uv/

# Testing artifacts
.pytest_cache
.coverage
.coverage.*
htmlcov/

# Type checking / linting
.mypy_cache
.ruff_cache

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# Docker files (not needed inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Environment files — never bake secrets into images
.env
.env.*
!.env.example

# CI
.github/
